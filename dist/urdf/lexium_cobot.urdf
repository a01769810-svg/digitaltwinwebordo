<?xml version="1.0"?>
<!--
  Lexium Cobot V26 (web build).  Refactor from V60: link3_elbow_connector
  is its own link hanging from link2_upper_arm via joint_elbow_connector
  (rpy = 0 π 0).  joint_3 and the rest of the chain hang from
  link_elbow_connector, inheriting the 180°-Y concentric pivot.
  POSE_LIB at runtime is regenerated for this URDF by re-IKing each V60
  pose's TCP world target.  Mesh paths point to /meshes/v53/{cobot,gripper}/
  so the existing STL bundle keeps working.
-->
<robot name="lexium_cobot_with_final_gripper">

  <material name="lexium_grey"><color rgba="0.40 0.40 0.45 1.0"/></material>
  <material name="lexium_dark"><color rgba="0.25 0.25 0.28 1.0"/></material>
  <material name="dark_gray"><color rgba="0.18 0.18 0.18 1"/></material>
  <material name="light_gray"><color rgba="0.70 0.70 0.70 1"/></material>
  <material name="medium_gray"><color rgba="0.45 0.45 0.45 1"/></material>
  <material name="blue_gray"><color rgba="0.25 0.33 0.42 1"/></material>
  <material name="red_gripper"><color rgba="0.85 0.05 0.05 1"/></material>

  <link name="world"/>
  <joint name="world_to_base_link_z_reference" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link0_base.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_dark"/>
    </visual>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/><child link="link1_shoulder"/>
    <origin xyz="0.1623 0.0867 0.0645" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" velocity="3.14" effort="50"/>
  </joint>

  <link name="link1_shoulder">
    <visual>
      <origin xyz="-0.1623 -0.0867 -0.0645" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link1_shoulder_rotation.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link1_shoulder"/><child link="link2_upper_arm"/>
    <origin xyz="-0.0115 0.0639 0" rpy="0 0 0.05"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.61799" upper="2.61799" velocity="3.14" effort="50"/>
  </joint>

  <link name="link2_upper_arm">
    <visual>
      <origin xyz="-0.1508 -0.1506 -0.0645" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link2_shoulder_connector.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
    <visual>
      <origin xyz="-0.1508 -0.1506 -0.0645" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link2_elbow_joint.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
  </link>

  <joint name="joint_elbow_connector" type="fixed">
    <parent link="link2_upper_arm"/>
    <child link="link_elbow_connector"/>
    <origin xyz="0.001060 0.243625 0.119967" rpy="0 3.14159265359 0"/>
  </joint>

  <link name="link_elbow_connector">
    <visual>
      <origin xyz="-0.151860 -0.394225 -0.172817" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link3_elbow_connector.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_elbow_connector"/><child link="link3_forearm"/>
    <origin xyz="0.002560 0.001375 0.113592" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.61799" upper="2.61799" velocity="3.14" effort="50"/>
  </joint>

  <link name="link3_forearm">
    <visual>
      <origin xyz="-0.1493 -0.3956 -0.2903" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link3_forearm.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
    <visual>
      <origin xyz="-0.1493 -0.3956 -0.2903" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link6_wrist3_cylinder.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
    <visual>
      <origin xyz="-0.1493 -0.3956 -0.2903" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link5_wrist2_body.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link3_forearm"/><child link="link4_wrist1"/>
    <origin xyz="-0.0060 0.2295 0.1244" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" velocity="3.14" effort="50"/>
  </joint>

  <link name="link4_wrist1">
    <visual>
      <origin xyz="-0.1433 -0.6251 -0.4147" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link4_wrist1_cylinder.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
    <visual>
      <origin xyz="-0.1433 -0.6251 -0.4147" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link5_wrist2_cylinder.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link4_wrist1"/><child link="link5_wrist2"/>
    <origin xyz="-0.0010 0.0465 -0.2300" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.09440" upper="2.09440" velocity="3.14" effort="50"/>
  </joint>

  <link name="link5_wrist2">
    <visual>
      <origin xyz="-0.1423 -0.6716 -0.1847" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link6_wrist3_upper_body.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_grey"/>
    </visual>
  </link>

  <joint name="joint_6" type="revolute">
    <parent link="link5_wrist2"/><child link="link6_wrist3"/>
    <origin xyz="-0.0040 0.0720 0.0898" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" velocity="3.14" effort="50"/>
  </joint>

  <link name="link6_wrist3">
    <visual>
      <origin xyz="-0.1383 -0.7436 -0.2745" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/cobot/link6_tool_flange.STL" scale="0.001 0.001 0.001"/></geometry>
      <material name="lexium_dark"/>
    </visual>
  </link>

  <joint name="joint_tool0" type="fixed">
    <parent link="link6_wrist3"/><child link="tool0"/>
    <origin xyz="0 0.068 0" rpy="0 0 0"/>
  </joint>
  <link name="tool0"/>

  <joint name="tool0_to_gripper_base" type="fixed">
    <parent link="tool0"/>
    <child link="gripper_base"/>
    <origin xyz="0 -0.07 0.015" rpy="0 0 0"/>
  </joint>
  <link name="gripper_base"/>

  <link name="stump_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry><mesh filename="/meshes/v53/gripper/stump.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/>
    </visual>
  </link>
  <joint name="stump_fixed_joint" type="fixed">
    <parent link="gripper_base"/><child link="stump_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="fixture_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry><mesh filename="/meshes/v53/gripper/fixture.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="light_gray"/>
    </visual>
  </link>
  <joint name="fixture_fixed_joint" type="fixed">
    <parent link="gripper_base"/><child link="fixture_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="fixture1_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry><mesh filename="/meshes/v53/gripper/fixture1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="medium_gray"/>
    </visual>
  </link>
  <joint name="fixture1_fixed_joint" type="fixed">
    <parent link="gripper_base"/><child link="fixture1_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="neck_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry><mesh filename="/meshes/v53/gripper/neck.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="blue_gray"/>
    </visual>
  </link>
  <joint name="neck_fixed_joint" type="fixed">
    <parent link="gripper_base"/><child link="neck_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="appendage_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry><mesh filename="/meshes/v53/gripper/appendage.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="red_gripper"/>
    </visual>
  </link>
  <joint name="appendage_prismatic_joint" type="prismatic">
    <parent link="gripper_base"/><child link="appendage_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.000" upper="0.028" effort="30" velocity="0.08"/>
  </joint>

  <link name="tcp_link"/>
  <joint name="tcp_fixed_joint" type="fixed">
    <parent link="appendage_link"/><child link="tcp_link"/>
    <origin xyz="0.000250 0.060250 0.076750" rpy="0 0 0"/>
  </joint>

  <link name="cafi_lateral_target_frame"/>
  <joint name="cafi_lateral_target_fixed_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="cafi_lateral_target_frame"/>
    <origin xyz="0.000000 0.016600 0.076750" rpy="0 0 0"/>
  </joint>

</robot>
