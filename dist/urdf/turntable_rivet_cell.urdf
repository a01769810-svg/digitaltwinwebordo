<?xml version="1.0"?>
<!--
  Flattened V53 turntable + rivet fixtures URDF for the web.
    - package:// mesh URIs rewritten to /meshes/v53/turntable/...
    - <collision> blocks dropped (visualization only).
    - debug grasp/pick marker frames dropped (not needed at runtime).
  Single revolute joint: table_rotation_joint drives the disc around +Z.
-->
<robot name="turntable_rivet_cell">

  <material name="dark_gray"><color rgba="0.15 0.15 0.15 1"/></material>
  <material name="industrial_gray"><color rgba="0.45 0.45 0.45 1"/></material>
  <material name="silver"><color rgba="0.78 0.78 0.78 1"/></material>
  <material name="motor_black"><color rgba="0.05 0.05 0.05 1"/></material>
  <!-- Reference-only CAFI placeholders inside the fixtures.  They show
       where the real CAFI lands on the disc, but the runtime CAFI mesh
       (driven by the sequence player) is what actually moves around the
       cell.  Alpha 0.22 keeps them as faint markers. -->
  <material name="cafi_blue"><color rgba="0.10 0.55 1.0 0.22"/></material>
  <material name="sensor_body"><color rgba="0.10 0.12 0.12 1"/></material>
  <material name="sensor_lens"><color rgba="0.90 0.05 0.05 1"/></material>
  <material name="sensor_ray"><color rgba="0.20 0.95 1.00 0.35"/></material>
  <material name="belt_black"><color rgba="0.01 0.01 0.01 1"/></material>

  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/gearbase.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/bearingbase.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/nema_base.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/bearingstand_1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/bearingstand_2.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/bearingstand_3.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/ballbearing_1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/ballbearing_2.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/ballbearing_3.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/ballbearing_center.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/bearingnut_1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/bearingnut_2.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
    <visual><origin xyz="-0.268973 -0.252455 -0.001530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/bearingnut_4.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark_gray"/></visual>
  </link>

  <!-- NEMA 17 placeholder body + shaft -->
  <joint name="base_to_nema17_motor" type="fixed">
    <parent link="base_link"/><child link="nema17_motor_link"/>
    <origin xyz="0.22936 0 0.05" rpy="0 0 0"/>
  </joint>
  <link name="nema17_motor_link">
    <visual><origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry><box size="0.042 0.042 0.040"/></geometry><material name="motor_black"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.025"/></geometry><material name="silver"/></visual>
  </link>

  <!-- Photoelectric sensor pedestal (fixed to base, watches fixture 1) -->
  <joint name="base_link_to_photoelectric_sensor_pedestal_fixture_1" type="fixed">
    <parent link="base_link"/><child link="photoelectric_sensor_pedestal_fixture_1_link"/>
    <origin xyz="0.255 -0.135 0.018" rpy="0 0 0"/>
  </joint>
  <link name="photoelectric_sensor_pedestal_fixture_1_link">
    <visual><origin xyz="0 0 -0.004" rpy="0 0 0"/>
      <geometry><box size="0.080 0.050 0.008"/></geometry><material name="industrial_gray"/></visual>
    <visual><origin xyz="0 0 0.040" rpy="0 0 0"/>
      <geometry><box size="0.020 0.020 0.080"/></geometry><material name="industrial_gray"/></visual>
  </link>

  <joint name="photoelectric_pedestal_to_sensor_fixture_1" type="fixed">
    <parent link="photoelectric_sensor_pedestal_fixture_1_link"/>
    <child link="photoelectric_sensor_fixture_1_link"/>
    <origin xyz="0 0 0.088" rpy="0 0 0"/>
  </joint>
  <link name="photoelectric_sensor_fixture_1_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.045 0.026 0.026"/></geometry><material name="sensor_body"/></visual>
    <visual><origin xyz="-0.025 0 0" rpy="0 1.570796 0"/>
      <geometry><cylinder radius="0.009" length="0.006"/></geometry><material name="sensor_lens"/></visual>
  </link>

  <joint name="photoelectric_sensor_to_light_ray" type="fixed">
    <parent link="photoelectric_sensor_fixture_1_link"/>
    <child link="photoelectric_light_ray_fixture_1_link"/>
    <origin xyz="-0.120 0 0" rpy="0 0 0"/>
  </joint>
  <link name="photoelectric_light_ray_fixture_1_link">
    <visual><origin xyz="0 0 0" rpy="0 1.570796 0"/>
      <geometry><cylinder radius="0.003" length="0.170"/></geometry><material name="sensor_ray"/></visual>
  </link>

  <!-- NEMA belt visuals -->
  <joint name="nema17_motor_to_belt_drive_visual" type="fixed">
    <parent link="nema17_motor_link"/><child link="nema_belt_drive_visual_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="nema_belt_drive_visual_link">
    <visual><origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><cylinder radius="0.030" length="0.014"/></geometry><material name="belt_black"/></visual>
    <visual><origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><cylinder radius="0.020" length="0.016"/></geometry><material name="silver"/></visual>
    <visual><origin xyz="-0.12218 0.030 0.01" rpy="0 0 0"/>
      <geometry><box size="0.244 0.010 0.012"/></geometry><material name="belt_black"/></visual>
    <visual><origin xyz="-0.12218 -0.030 0.01" rpy="0 0 0"/>
      <geometry><box size="0.244 0.010 0.012"/></geometry><material name="belt_black"/></visual>
  </link>

  <joint name="turntable_to_belt_driven_pulley_visual" type="fixed">
    <parent link="turntable_link"/><child link="turntable_belt_driven_pulley_visual_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="turntable_belt_driven_pulley_visual_link">
    <visual><origin xyz="0 0 -0.018" rpy="0 0 0"/>
      <geometry><cylinder radius="0.068" length="0.012"/></geometry><material name="belt_black"/></visual>
  </link>

  <!-- Main rotating disc -->
  <joint name="table_rotation_joint" type="revolute">
    <parent link="base_link"/><child link="turntable_link"/>
    <origin xyz="-0.015 0 0.078" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.141593" upper="3.141593" effort="30" velocity="0.60"/>
  </joint>
  <link name="turntable_link">
    <visual><origin xyz="-0.253973 -0.252455 -0.079530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/turntable_disc.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="silver"/></visual>
    <visual><origin xyz="-0.253973 -0.252455 -0.079530" rpy="0 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/bearingsprocket.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="silver"/></visual>
  </link>

  <!-- Rivet fixture 1 on disc -->
  <joint name="turntable_to_rivet_fixture_1" type="fixed">
    <parent link="turntable_link"/><child link="rivet_fixture_1_link"/>
    <origin xyz="0 -0.030 0.004" rpy="0 0 0"/>
  </joint>
  <link name="rivet_fixture_1_link">
    <visual><origin xyz="-0.209707 -0.015035 -0.000132" rpy="1.570796 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/rivet_fixture_top.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="industrial_gray"/></visual>
    <visual><origin xyz="-0.209707 -0.015035 -0.000132" rpy="1.570796 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/rivet_fixture_bottom.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="industrial_gray"/></visual>
    <visual><origin xyz="-0.209707 -0.015035 -0.000132" rpy="1.570796 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/piston_good.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="industrial_gray"/></visual>
  </link>

  <!-- CAFI part inside fixture 1 -->
  <joint name="fixture_1_to_cafi" type="fixed">
    <parent link="rivet_fixture_1_link"/><child link="cafi_part_1_link"/>
    <origin xyz="0.003276 -0.071389 0.022476" rpy="0 0 0"/>
  </joint>
  <link name="cafi_part_1_link">
    <visual><origin xyz="-0.212983 0.056354 -0.022608" rpy="1.57079632679 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/cafi.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="cafi_blue"/></visual>
  </link>

  <!-- Rivet fixture 2 (rotated 180 deg from fixture 1) -->
  <joint name="turntable_to_rivet_fixture_2" type="fixed">
    <parent link="turntable_link"/><child link="rivet_fixture_2_link"/>
    <origin xyz="0 0.030 0.004" rpy="0 0 3.141593"/>
  </joint>
  <link name="rivet_fixture_2_link">
    <visual><origin xyz="-0.209707 -0.015035 -0.000132" rpy="1.570796 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/rivet_fixture_top.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="industrial_gray"/></visual>
    <visual><origin xyz="-0.209707 -0.015035 -0.000132" rpy="1.570796 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/rivet_fixture_bottom.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="industrial_gray"/></visual>
    <visual><origin xyz="-0.209707 -0.015035 -0.000132" rpy="1.570796 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/piston_good.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="industrial_gray"/></visual>
  </link>

  <joint name="fixture_2_to_cafi" type="fixed">
    <parent link="rivet_fixture_2_link"/><child link="cafi_part_2_link"/>
    <origin xyz="0.003276 -0.071389 0.022476" rpy="0 0 0"/>
  </joint>
  <link name="cafi_part_2_link">
    <visual><origin xyz="-0.212983 0.056354 -0.022608" rpy="1.57079632679 0 0"/>
      <geometry><mesh filename="/meshes/v53/turntable/cafi.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="cafi_blue"/></visual>
  </link>

</robot>
