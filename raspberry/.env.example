# Configuración de la mesa rotatoria (Raspberry Pi 4).
# Copia este archivo a .env y ajústalo.  NO commitees el .env real.

# --- Pinout NEMA (BCM) ---  confirmado por el equipo: STEP=17, DIR=27
STEP_PIN=17
DIR_PIN=27

# --- Conversión / velocidad ---
STEPS_180=185        # pasos para girar 180° (calibrar en hardware)
STEP_DELAY=0.005     # segundos por flanco; más bajo = más rápido
DWELL_S=1.0          # pausa en cada extremo del ciclo A↔B

# --- Servidor ---
HOST=0.0.0.0
PORT=8000

# --- Modo ---
# Déjalo comentado: en la RPi usa GPIO real; en una laptop sin GPIO entra en
# mock automáticamente.  Pon MOCK=true para forzar simulación aun con GPIO.
# MOCK=true
