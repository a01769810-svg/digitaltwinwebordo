# ─────────────────────────────────────────────────────────────────────────────
# raspberry_turntable_env_example.env
#
# Configuración de la mesa rotatoria.  Copia este archivo a `.env` en la
# Raspberry y ajusta los valores reales.  NO subas tu .env real al repo.
#
#   cp raspberry_turntable_env_example.env .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Pines (numeración BCM) ──────────────────────────────────────────────────
# A4988 / NEMA 17
STEP_PIN=17
DIR_PIN=27
# Limit switches (pull-up interno; sin presionar=HIGH, presionado=LOW)
LIMIT_HOME_PIN=22
LIMIT_WORK_PIN=23

# ── Movimiento ──────────────────────────────────────────────────────────────
# Pasos para girar 180° (HOME<->WORK). DEBE calibrarse en hardware:
# depende de microstepping del A4988 y de la reductora/correa de la mesa.
# (Prueba_con_motor.py de referencia usaba 185; ajústalo con el stepper_test.)
STEPS_180=185
# Segundos entre flancos STEP (más bajo = más rápido; cuidado con perder pasos).
STEP_DELAY=0.005
# Tope de seguridad open-loop: máximo de pasos por movimiento antes de marcar FAULT.
MAX_MOVE_STEPS=4000

# ── Remachado ───────────────────────────────────────────────────────────────
# Dwell del remachado físico (simulado por ahora). El brief pide 10 s.
RIVET_SECONDS=10

# ── Modo ────────────────────────────────────────────────────────────────────
# 1 = forzar MOCK (sin GPIO, para correr en laptop). 0 = usar GPIO real si existe.
TURNTABLE_MOCK=0
